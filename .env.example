# wikifi runtime — local Ollama by default. All keys are optional;
# omit any to accept the default declared in wikifi/config.py.

# LLM provider id. Only "ollama" is supported in v1.
WIKIFI_PROVIDER=ollama

# Model identifier passed to the provider. Must be available in `ollama list`.
WIKIFI_MODEL=qwen3.6:27b

# Ollama HTTP endpoint.
WIKIFI_OLLAMA_HOST=http://localhost:11434

# Per-request timeout in seconds. Default is 900 (15 min) so high-thinking
# Qwen3 models have headroom on real source files — drop this if you switch
# to a faster model or lower thinking level.
WIKIFI_REQUEST_TIMEOUT=900

# Skip files larger than this during extraction (bytes).
WIKIFI_MAX_FILE_BYTES=200000

# Skip files whose stripped content is shorter than this (bytes). Avoids
# wasting LLM time on stubs like `__init__.py` files containing only a
# version string — thinking-capable models tend to wander indefinitely on
# near-empty input.
WIKIFI_MIN_CONTENT_BYTES=64

# Tree depth fed to the Stage 1 introspection pass.
WIKIFI_INTROSPECTION_DEPTH=3

# Thinking-mode level for reasoning-capable models (Qwen3, DeepSeek-R1).
# Default "high" — wikifi prioritizes wiki quality over walk speed; expect
# 1-3 minutes per real file at this level on a local 27B model. The
# min_content_bytes guard prevents the thinking-runaway-on-stubs failure
# mode that this setting could otherwise trigger.
# Other accepted values:
#   "medium" / "low"   (Qwen3-style — faster, less depth)
#   "true"             (DeepSeek-style)
#   "false"            (only safe with non-thinking models — Qwen3
#                       ignores the JSON-schema constraint when thinking
#                       is fully off and emits free text instead)
WIKIFI_THINK=high
